FFLOGS_CLIENT_ID=your-fflogs-v2-client-id
FFLOGS_CLIENT_SECRET=your-fflogs-v2-client-secret
GOOGLE_SERVICE_ACCOUNT_KEY={"client_email":"...","private_key":"..."}
# User-owned spreadsheet shared with the service account as editor.
# The app adds one tab per generated plan (service accounts cannot own files).
MITIGATION_SPREADSHEET_ID=your-spreadsheet-id
